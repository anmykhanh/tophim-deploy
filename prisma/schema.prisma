generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model actors {
  id             Int           @id @default(autoincrement())
  name           String        @db.VarChar(100)
  slug           String        @unique @db.VarChar(100)
  avatar         String?       @db.VarChar(500)
  bio            String?       @db.Text
  imdb_id        String?       @db.VarChar(20)
  gender         String?       @db.VarChar(20)
  birthday       String?       @db.VarChar(50)
  place_of_birth String?       @db.VarChar(255)
  deathday       String?       @db.VarChar(50)
  imdb_synced_at DateTime?     @db.Timestamp(0)
  tmdb_id        Int?
  actor_favorites actor_favorites[]
  movie_actor    movie_actor[]
}

model categories {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(100)
  slug           String           @unique @db.VarChar(100)
  type           categories_type
  color          String?          @db.VarChar(20)
  description    String?          @db.Text
  status         Boolean?         @default(true)
  order_num      Int?             @default(0)
  movie_category movie_category[]
}

model comment_likes {
  id         Int      @id @default(autoincrement())
  comment_id Int
  user_id    Int
  created_at DateTime @default(now()) @db.Timestamp(0)

  @@unique([comment_id, user_id])
}

model comments {
  id           Int       @id @default(autoincrement())
  user_id      Int
  movie_id     Int
  episode_id   Int?
  content      String    @db.Text
  status       Boolean?  @default(true)
  created_at   DateTime  @default(now()) @db.Timestamp(0)
  parent_id    Int?
  gif_url      String?   @db.VarChar(255)
  is_spoiler   Boolean?  @default(false)
  is_pinned    Boolean?  @default(false)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  movies       movies    @relation(fields: [movie_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  episodes     episodes? @relation(fields: [episode_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([episode_id])
  @@index([movie_id])
  @@index([user_id])
}

model daily_watch_stats {
  id         Int      @id @default(autoincrement())
  user_id    Int
  watch_date DateTime @db.Date
  watch_time Int?     @default(0)

  @@unique([user_id, watch_date])
}

model episodes {
  id          Int        @id @default(autoincrement())
  movie_id    Int
  server_name String     @db.VarChar(100)
  name        String     @db.VarChar(100)
  slug        String     @db.VarChar(100)
  video_url    String     @db.VarChar(500)
  subtitle_url String?    @db.VarChar(500)
  order_num    Int?       @default(0)
  created_at   DateTime   @default(now()) @db.Timestamp(0)
  comments     comments[]
  movies      movies     @relation(fields: [movie_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  episode_subtitles episode_subtitles[]

  @@index([movie_id])
}

model episode_subtitles {
  id          Int      @id @default(autoincrement())
  episode_id  Int
  label       String   @db.VarChar(100)
  language    String   @db.VarChar(20)
  url         String   @db.VarChar(500)
  created_at  DateTime @default(now()) @db.Timestamp(0)
  episodes    episodes @relation(fields: [episode_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([episode_id])
}

model error_reports {
  id         Int                   @id @default(autoincrement())
  user_id    Int?
  movie_id   Int?
  episode_id Int?
  message    String                @db.Text
  status     error_reports_status? @default(pending)
  created_at DateTime              @default(now()) @db.Timestamp(0)
  users      users?                @relation(fields: [user_id], references: [id], onUpdate: Restrict)
  movies     movies?               @relation(fields: [movie_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([movie_id])
  @@index([user_id])
}

model favorites {
  id         Int      @id @default(autoincrement())
  user_id    Int
  movie_id   Int
  created_at DateTime @default(now()) @db.Timestamp(0)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  movies     movies   @relation(fields: [movie_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([user_id, movie_id])
  @@index([movie_id])
}

model actor_favorites {
  id         Int      @id @default(autoincrement())
  user_id    Int
  actor_id   Int
  created_at DateTime @default(now()) @db.Timestamp(0)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  actors     actors   @relation(fields: [actor_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([user_id, actor_id])
  @@index([actor_id])
}

model menus {
  id          Int      @id @default(autoincrement())
  label       String   @db.VarChar(100)
  type        String   @db.VarChar(50)
  url         String?  @db.VarChar(255)
  icon        String?  @db.VarChar(100)
  parent_id   Int?
  order_num   Int?     @default(0)
  status      Boolean? @default(true)
  menus       menus?   @relation("menusTomenus", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  other_menus menus[]  @relation("menusTomenus")

  @@index([parent_id])
}

model movie_actor {
  movie_id Int
  actor_id Int
  movies   movies @relation(fields: [movie_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  actors   actors @relation(fields: [actor_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@id([movie_id, actor_id])
  @@index([actor_id])
  @@index([movie_id, actor_id])
}

model movie_category {
  movie_id    Int
  category_id Int
  movies      movies     @relation(fields: [movie_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  categories  categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@id([movie_id, category_id])
  @@index([category_id])
  @@index([movie_id, category_id])
}

model movie_folder_items {
  id            Int           @id @default(autoincrement())
  folder_id     Int
  movie_id      Int
  created_at    DateTime      @default(now()) @db.Timestamp(0)
  movie_folders movie_folders @relation(fields: [folder_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  movies        movies        @relation(fields: [movie_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([folder_id, movie_id])
  @@index([movie_id])
}

model movie_folders {
  id                 Int                  @id @default(autoincrement())
  user_id            Int
  name               String               @db.VarChar(255)
  slug               String               @unique @db.VarChar(255)
  is_public          Boolean?             @default(true)
  created_at         DateTime             @default(now()) @db.Timestamp(0)
  movie_folder_items movie_folder_items[]
  users              users                @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([user_id])
}

model movies {
  id                 Int                  @id @default(autoincrement())
  title              String               @db.VarChar(255)
  original_title     String?              @db.VarChar(255)
  slug               String               @unique @db.VarChar(255)
  description        String?              @db.Text
  poster_url         String?              @db.VarChar(500)
  thumb_url          String?              @db.VarChar(500)
  trailer_url        String?              @db.VarChar(500)
  type               String?              @db.VarChar(50)
  status             String?              @db.VarChar(50)
  year               Int?
  duration           String?              @db.VarChar(50)
  quality            String?              @db.VarChar(50)
  language           String?              @db.VarChar(50)
  is_hot             Boolean?             @default(false)
  hot_priority       Int?                 @default(0)
  views              Int?                 @default(0)
  api_source         String?              @db.VarChar(50)
  api_movie_id       String?              @db.VarChar(100)
  created_at         DateTime             @default(now()) @db.Timestamp(0)
  updated_at         DateTime             @default(now()) @db.Timestamp(0)
  director           String?              @db.VarChar(255)
  imdb_id            String?              @db.VarChar(20)
  imdb_rating        Decimal?             @db.Decimal(3, 1)
  imdb_votes         String?              @db.VarChar(20)
  tmdb_id            Int?
  logo_url           String?              @db.VarChar(255)
  chieurap           Boolean?             @default(false)
  is_copyright       Boolean?             @default(false)
  sub_docquyen       Boolean?             @default(false)
  episode_current    String?              @db.VarChar(100)
  showtimes          String?              @db.Text
  server_priority    String?              @db.VarChar(500)
  comments           comments[]
  episodes           episodes[]
  error_reports      error_reports[]
  favorites          favorites[]
  movie_actor        movie_actor[]
  movie_category     movie_category[]
  movie_folder_items movie_folder_items[]
  movie_views_stats  movie_views_stats[]
  watch_rooms        watch_rooms[]

  @@index([is_hot])
  @@index([original_title])
  @@index([status])
  @@index([title])
  @@index([type])
  @@index([updated_at])
  @@index([views])
  @@index([year])
}

model settings {
  key         String  @id @db.VarChar(50)
  value       String? @db.Text
  description String? @db.VarChar(255)
}

model users {
  id                   Int                   @id @default(autoincrement())
  name                 String                @db.VarChar(100)
  email                String                @unique @db.VarChar(150)
  password             String                @db.VarChar(255)
  reset_token          String?               @db.VarChar(64)
  reset_expires        DateTime?             @db.Timestamp(0)
  avatar               String?               @db.VarChar(255)
  role                 users_role?           @default(user)
  role_id              Int?
  created_at           DateTime              @default(now()) @db.Timestamp(0)
  updated_at           DateTime              @default(now()) @db.Timestamp(0)
  gender               String?               @db.VarChar(20)
  banned_until         DateTime?             @db.Timestamp(0)
  email_verified       Boolean               @default(false)
  last_ip              String?               @db.VarChar(45)
  verification_expires DateTime?             @db.Timestamp(0)
  verification_token   String?               @db.VarChar(64)
  label_id             Int?
  comments             comments[]
  error_reports        error_reports[]
  actor_favorites      actor_favorites[]
  favorites            favorites[]
  movie_folders        movie_folders[]
  notification_reads   notification_reads[]
  notifications        notifications[]
  user_logs            user_logs[]
  user_labels          user_labels?          @relation(fields: [label_id], references: [id], onUpdate: Restrict)
  roles                roles?                @relation(fields: [role_id], references: [id], onUpdate: Restrict)
  watch_room_messages  watch_room_messages[]
  watch_rooms          watch_rooms[]
  movie_requests       movie_requests[]
  article_comments     article_comments[]
  articles             articles[]

  @@index([label_id])
  @@index([role_id])
}

model roles {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  permissions Json?
  created_at  DateTime @default(now()) @db.Timestamp(0)
  users       users[]
}

model user_logs {
  id         Int      @id @default(autoincrement())
  user_id    Int
  action     String   @db.VarChar(100)
  details    String?  @db.Text
  ip_address String?  @db.VarChar(45)
  created_at DateTime @default(now()) @db.Timestamp(0)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model watch_history {
  id              Int      @id @default(autoincrement())
  user_id         Int
  movie_id        Int
  watch_time      Int?     @default(0)
  last_watched_at DateTime @default(now()) @db.Timestamp(0)
  episode_id      Int?
  duration        Int?     @default(0)

  @@unique([user_id, movie_id])
}

model watch_later {
  id         Int      @id @default(autoincrement())
  user_id    Int
  movie_id   Int
  created_at DateTime @default(now()) @db.Timestamp(0)

  @@unique([user_id, movie_id])
}

model watch_room_messages {
  id          Int         @id @default(autoincrement())
  room_id     String      @db.VarChar(50)
  user_id     Int
  message     String      @db.Text
  created_at  DateTime    @default(now()) @db.Timestamp(0)
  watch_rooms watch_rooms @relation(fields: [room_id], references: [room_id], onDelete: Cascade, onUpdate: Restrict)
  users       users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([room_id])
  @@index([user_id])
}

model watch_rooms {
  room_id             String                @id @db.VarChar(50)
  host_id             Int
  movie_id            Int
  episode_id          Int
  server_name         String                @db.VarChar(100)
  title               String                @db.VarChar(255)
  capacity            Int?                  @default(10)
  is_public           Boolean?              @default(true)
  status              String?               @default("paused") @db.VarChar(20)
  current_time        Float?                @default(0)
  scheduled_at        DateTime?             @db.Timestamp(0)
  created_at          DateTime              @default(now()) @db.Timestamp(0)
  updated_at          DateTime              @default(now()) @db.Timestamp(0)
  watch_room_messages watch_room_messages[]
  users               users                 @relation(fields: [host_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  movies              movies                @relation(fields: [movie_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([host_id])
  @@index([movie_id])
}

model notifications {
  id                 Int                  @id @default(autoincrement())
  user_id            Int?
  type               String               @default("system") @db.VarChar(50)
  title              String               @db.VarChar(255)
  message            String               @db.Text
  link               String?              @db.VarChar(255)
  created_at         DateTime             @default(now()) @db.Timestamp(0)
  notification_reads notification_reads[]
  users              users?               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([user_id])
}

model notification_reads {
  id              Int           @id @default(autoincrement())
  notification_id Int
  user_id         Int
  read_at         DateTime      @default(now()) @db.Timestamp(0)
  notifications   notifications @relation(fields: [notification_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  users           users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([notification_id, user_id])
  @@index([user_id])
}

model contacts {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  email      String   @db.VarChar(150)
  subject    String?  @db.VarChar(255)
  message    String   @db.Text
  status     String?  @default("pending") @db.VarChar(20)
  created_at DateTime @default(now()) @db.Timestamp(0)
}

model movie_views_stats {
  id        Int      @id @default(autoincrement())
  movie_id  Int
  view_date DateTime @db.Date
  views     Int      @default(1)
  movies    movies   @relation(fields: [movie_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([movie_id, view_date])
  @@index([movie_id])
}

model tv_linking_codes {
  id         Int      @id @default(autoincrement())
  code       String   @unique @db.VarChar(6)
  user_id    Int
  created_at DateTime @default(now()) @db.Timestamp(0)
  expires_at DateTime @db.Timestamp(0)
}

model user_labels {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  color      String   @db.VarChar(20)
  created_at DateTime @default(now()) @db.Timestamp(0)
  users      users[]
}

model active_sessions {
  session_id  String   @id @db.VarChar(100)
  user_id     Int?
  ip_address  String?  @db.VarChar(45)
  last_active DateTime @default(now()) @db.Timestamp(0)
  is_member   Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamp(0)

  @@index([last_active])
}

enum categories_type {
  genre
  country
  collection
  schedule
}

enum error_reports_status {
  pending
  resolved
}

enum users_role {
  user
  admin
}

model movie_requests {
  id             Int      @id @default(autoincrement())
  user_id        Int?
  title          String   @db.VarChar(255)
  original_title String?  @db.VarChar(255)
  imdb_url       String?  @db.VarChar(500)
  reference_url  String?  @db.VarChar(500)
  description    String   @db.Text
  status         String   @default("pending") @db.VarChar(20) // pending, completed, rejected
  created_at     DateTime @default(now()) @db.Timestamp(0)
  users          users?   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model articles {
  id               Int                @id @default(autoincrement())
  title            String             @db.VarChar(255)
  slug             String             @unique @db.VarChar(255)
  description      String?            @db.VarChar(500)
  category         String             @default("Thông tin") @db.VarChar(50)
  content          String             @db.Text
  thumbnail        String?            @db.VarChar(500)
  views            Int                @default(0)
  status           Boolean            @default(true)
  created_at       DateTime           @default(now()) @db.Timestamp(0)
  updated_at       DateTime           @default(now()) @db.Timestamp(0)
  author_id        Int?
  users            users?             @relation(fields: [author_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  article_comments article_comments[]

  @@index([author_id])
}

model article_comments {
  id           Int      @id @default(autoincrement())
  user_id      Int
  article_id   Int
  content      String   @db.Text
  status       Boolean? @default(true)
  created_at   DateTime @default(now()) @db.Timestamp(0)
  parent_id    Int?
  gif_url      String?  @db.VarChar(255)
  is_spoiler   Boolean? @default(false)
  is_pinned    Boolean? @default(false)
  users        users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  articles     articles @relation(fields: [article_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([article_id])
  @@index([user_id])
}

model servers {
  id           Int      @id @default(autoincrement())
  name         String   @unique @db.VarChar(100)
  display_name String   @db.VarChar(100)
  priority     Int      @default(0)
  created_at   DateTime @default(now()) @db.Timestamp(0)
  updated_at   DateTime @default(now()) @db.Timestamp(0)
}
